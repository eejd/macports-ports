# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0

name                xcode-copilot-server
version             3.4.0
revision            0

categories          devel
license             MIT
maintainers         {@eejd} openmaintainer

description         GitHub Copilot proxy server for Xcode's AI coding features

long_description    ${name} is a proxy API server that lets you use GitHub \
                    Copilot as an LLM provider in Xcode. It wraps the GitHub \
                    Copilot SDK and exposes it as an OpenAI-compatible, \
                    Anthropic-compatible, or OpenAI Responses-compatible API \
                    on localhost, allowing Xcode to use Copilot as a custom \
                    model provider or as the backend for Claude Agent and \
                    Codex Agent. Supports launchd socket activation for \
                    on-demand background operation.

homepage            https://github.com/theblixguy/xcode-copilot-server

master_sites        https://registry.npmjs.org/${name}/-/

distname            ${name}-${version}
extract.suffix      .tgz

checksums           rmd160  a92e4e4fff874905babcb99c3622e7c8486453fa \
                    sha256  152b617cd329c73f0a930d85a1ece5137aa000940d62caa8448d997b0bdf3f20 \
                    size    76019

worksrcdir          package

# Upstream requires Node.js >= 25.6.0 (see .node-version and package.json
# engines field). nodejs24 is the closest currently available in MacPorts;
# update this dependency to nodejs25 once that port is available.
depends_lib         path:bin/node:nodejs24
depends_build       path:bin/npm:npm11

use_configure       no

build {
    # Install only production (runtime) dependencies.
    # This also triggers koffi's postinstall to download its prebuilt native
    # binary for the current platform.
    system -W ${worksrcpath} "${prefix}/bin/npm install --omit=dev"
}

post-build {
    # Replace the generic env-based shebang with the MacPorts node path so
    # the script uses the port's Node.js installation at runtime.
    reinplace "s|#!/usr/bin/env node|#!${prefix}/bin/node|" \
        ${worksrcpath}/dist/index.js
}

post-build {
    # +bash_mcp: install bash-mcp into the package's node_modules so it is
    # available at runtime without network access or npx.
    if {[variant_isset bash_mcp]} {
        system -W ${worksrcpath} "${prefix}/bin/npm install bash-mcp"
    }
}

variant bash_mcp description {Install bash-mcp MCP server for shell access in the OpenAI provider} {
    # Installs bash-mcp into the package tree and wires it into
    # openai.mcpServers in config.json5.  autoApprovePermissions is set to []
    # so every MCP tool call — including bash-mcp invocations AND xcrun
    # mcpbridge — produces an explicit prompt, matching VS Code's default
    # behaviour where shell commands require user confirmation.
}

test {
    # 1. CLI reports the expected version (no network or auth required).
    set out [string trim [exec ${prefix}/bin/node ${worksrcpath}/dist/index.js --version]]
    if {${out} ne ${version}} {
        return -code error "${name} --version reported '${out}', expected '${version}'"
    }

    # 2. Bundled Copilot SDK is present — confirms npm install succeeded.
    if {![file exists ${worksrcpath}/node_modules/@github/copilot/index.js]} {
        return -code error "Copilot SDK missing: node_modules/@github/copilot/index.js not found"
    }

    # 3. Shebang was patched to the MacPorts node binary.
    set fd [open ${worksrcpath}/dist/index.js r]
    set shebang [gets ${fd}]
    close ${fd}
    if {${shebang} ne "#!${prefix}/bin/node"} {
        return -code error "shebang not patched: got '${shebang}'"
    }
}

destroot {
    set nm_dir ${destroot}${prefix}/lib/node_modules

    # Create node_modules directory and copy the package tree (dist/, scripts/,
    # config.json5, package.json, and installed node_modules/) into it.
    xinstall -d ${nm_dir}
    file copy ${worksrcpath} ${nm_dir}/${name}

    # Ensure the main entry-point is executable.
    file attributes ${nm_dir}/${name}/dist/index.js -permissions 0755

    # Expose the binary via the standard MacPorts bin directory.
    ln -s ${prefix}/lib/node_modules/${name}/dist/index.js \
        ${destroot}${prefix}/bin/${name}
}
post-destroot {
    # SECURITY: The shipped config.json5 defaults to
    #   autoApprovePermissions: ["read", "mcp"]
    # The "read" entry causes the Copilot SDK to silently auto-approve all
    # file-read requests from its built-in file tools, which triggers macOS
    # TCC permission dialogs for Photos, Music, Documents, etc. on first use.
    # Without +bash_mcp: restrict to "mcp" only so the user is always prompted
    # before any filesystem access is granted.
    # With +bash_mcp: set to [] — bash-mcp tool calls are also "mcp" kind, so
    # leaving "mcp" would silently auto-approve shell commands.  Clearing the
    # list means every MCP call (including xcrun mcpbridge) prompts explicitly,
    # matching VS Code's behaviour where shell execution requires confirmation.
    set cfg ${destroot}${prefix}/lib/node_modules/${name}/config.json5
    if {[variant_isset bash_mcp]} {
        reinplace {s|autoApprovePermissions: \["read", "mcp"\]|autoApprovePermissions: []|} ${cfg}
        # Inject bash-mcp after the xcode MCP server entry in openai.mcpServers.
        set fd [open ${cfg} r]
        set content [read ${fd}]
        close ${fd}
        set old_entry "      allowedTools: \[\"*\"\],\n      },\n    },"
        set new_entry "      allowedTools: \[\"*\"\],\n      },\n      bash: \{\n        type: \"local\",\n        command: \"${prefix}/bin/node\",\n        args: \[\"${prefix}/lib/node_modules/${name}/node_modules/bash-mcp/index.js\"\],\n      },\n    },"
        set content [string map [list ${old_entry} ${new_entry}] ${content}]
        set fd [open ${cfg} w]
        puts -nonewline ${fd} ${content}
        close ${fd}
    } else {
        reinplace {s|autoApprovePermissions: \["read", "mcp"\]|autoApprovePermissions: ["mcp"]|} ${cfg}
    }
}
notes "
=== Authentication ===

${name} requires a GitHub Copilot subscription. You must authenticate
before starting the server. Choose one of the following methods:

RECOMMENDED — GitHub CLI (port:gh):

  sudo port install gh
  gh auth login

  This stores a token in the macOS Keychain and is the most seamless option.
  It also works automatically when the server is installed as a launchd agent.

ALTERNATIVE — Environment variable:

  Create a GitHub personal access token at https://github.com/settings/tokens
  with Copilot access (classic PAT: no special scope needed beyond your
  Copilot subscription; fine-grained PAT: enable GitHub Copilot permission).
  Then export it in your shell startup file:

    export GITHUB_TOKEN=your_token_here

  For the launchd agent, set it before installing:

    launchctl setenv GITHUB_TOKEN your_token_here
    ${name} install-agent

  NOTE: If you export GITHUB_TOKEN, it will be embedded in the agent plist
  at ~/Library/LaunchAgents/. Set appropriate file permissions if concerned.

NOTE — VS Code Copilot credentials are NOT shared:
  Even if you are already authenticated with GitHub Copilot in VS Code,
  ${name} cannot access those credentials (VS Code stores them in its own
  private Keychain entries). You must authenticate separately using one of
  the methods above.

=== Running modes ===

OPTION A — Manual (foreground, useful for testing):

  ${name}                          # all providers, port 8080
  ${name} --proxy openai           # custom model provider only
  ${name} --proxy claude           # Claude Agent backend only
  ${name} --proxy codex            # Codex Agent backend only
  ${name} --port 9090              # use a different port

OPTION B — Launchd agent (recommended for daily use):

  ${name} install-agent

  Uses macOS socket activation: launchd owns the socket on port 8080
  and starts the server only when Xcode connects. After --idle-timeout
  minutes of inactivity (default: 60) the server shuts itself down;
  launchd will restart it on the next connection. Run install-agent
  once; it persists across reboots without keeping a terminal open.

  Options (passed at install time, embedded in the plist):
    --port <number>          port to listen on (default: 8080)
    --proxy <provider>       openai, claude, codex, or all (default: all)
    --idle-timeout <minutes> inactivity shutdown (default: 60)
    --log-level <level>      debug, info, warn, error (default: info)

  IMPORTANT — do NOT run install-agent from a VS Code integrated terminal.
  VS Code injects its own copilotCli extension path into the shell PATH, and
  that path gets baked into the launchd plist. The agent will then use VS
  Code's bundled Copilot CLI binary rather than the one shipped with this
  port, creating a hidden dependency on VS Code remaining installed and its
  extension staying at the same path.

  Always run install-agent from a plain Terminal.app or iTerm2 session that
  does not have VS Code's PATH additions. If you already installed the agent
  from a VS Code terminal, fix the plist PATH in place:

    /usr/libexec/PlistBuddy -c \\
      'Set :EnvironmentVariables:PATH ${prefix}/bin:${prefix}/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin' \\
      ~/Library/LaunchAgents/com.${name}.plist
    launchctl unload ~/Library/LaunchAgents/com.${name}.plist
    launchctl load  ~/Library/LaunchAgents/com.${name}.plist

  Verify the fix: ps aux | grep copilot — the SDK subprocess path should
  show .../node_modules/@github/copilot/index.js, NOT .../copilotCli/...

  To start at login instead of on-demand, add RunAtLoad to the plist:
    /usr/libexec/PlistBuddy -c 'Add :RunAtLoad bool true' \\
      ~/Library/LaunchAgents/com.${name}.plist
    launchctl unload ~/Library/LaunchAgents/com.${name}.plist
    launchctl load  ~/Library/LaunchAgents/com.${name}.plist

  Uninstall the agent:
    ${name} uninstall-agent

=== Logs ===

When running as a launchd agent, logs are written to:
  ~/Library/Logs/${name}.out.log   (stdout / server events)
  ~/Library/Logs/${name}.err.log   (stderr / SDK warnings)

Follow live:
  tail -f ~/Library/Logs/${name}.out.log

Temporarily switch to debug logging without reinstalling:
  /usr/libexec/PlistBuddy -c 'Set :ProgramArguments:6 debug' \\
    ~/Library/LaunchAgents/com.${name}.plist
  launchctl unload ~/Library/LaunchAgents/com.${name}.plist
  launchctl load   ~/Library/LaunchAgents/com.${name}.plist
  # Restore:
  /usr/libexec/PlistBuddy -c 'Set :ProgramArguments:6 info' \\
    ~/Library/LaunchAgents/com.${name}.plist
  launchctl unload ~/Library/LaunchAgents/com.${name}.plist
  launchctl load   ~/Library/LaunchAgents/com.${name}.plist

  CAUTION: index 6 is the level value; index 5 is the '--log-level' flag.
  Editing the wrong index corrupts the plist and prevents startup.
  Verify by checking ProgramArguments:
    /usr/libexec/PlistBuddy -c 'Print :ProgramArguments' \\
      ~/Library/LaunchAgents/com.${name}.plist

Check agent status:
  launchctl list | grep ${name}

See '${name} --help' for the full CLI reference.
=== Privacy & permissions ===

The server ships a config file at:
  ${prefix}/lib/node_modules/${name}/config.json5

Security defaults applied by this port:
  autoApprovePermissions: \[\"mcp\"\]   # Xcode MCP tool calls only

The original npm tarball defaults to \[\"read\", \"mcp\"\]. The \"read\" entry
causes the Copilot SDK to silently auto-approve all file-read requests from
its built-in file tools, which in turn triggers macOS TCC permission dialogs
for Photos, Music, Documents, and other protected directories on first use.
This port patches the default to \[\"mcp\"\] during installation.

Edit config.json5 to fine-tune other settings such as:
  allowedTools: \[\"*\"\]   # which Xcode MCP tools the model may call
Change \"*\" to an explicit list if you want to restrict tool access, e.g.:
  allowedTools: \[\"createFile\", \"readFile\", \"editFile\"\]

Note: changes to config.json5 are preserved across minor updates but will
be reset if you run 'port reinstall ${name}'.
=== +bash_mcp variant ===

Install with terminal access for the OpenAI provider:

  sudo port install ${name} +bash_mcp

This adds a bash-mcp MCP server to the OpenAI provider alongside Xcode's
xcrun mcpbridge tools.  The Copilot session can then run arbitrary shell
commands (git, grep, make, etc.) in addition to using Xcode's built-in
file and index tools.

Permissions with +bash_mcp:
  autoApprovePermissions: []   # prompt for every MCP tool call

Since bash-mcp tool calls and xcrun mcpbridge tool calls share the same
"mcp" permission kind, there is no way to approve Xcode tools silently
while prompting only for shell commands.  Setting autoApprovePermissions
to [] means you will be prompted for both.  This matches VS Code's default
behaviour where shell execution requires an explicit user confirmation.

If you find the mcpbridge prompts too noisy, add "mcp" back:
  autoApprovePermissions: ["mcp"]   # silent for all MCP calls

Or narrow it if a future release of the Copilot SDK introduces separate
permission kinds for shell vs MCP tools.

SECURITY: bash-mcp runs with your user account's full permissions.
It can read and write arbitrary files, run git, install packages, and
execute any command your account can.  Review each tool call prompt
before approving it, and do not run the agent unattended.
=== Node.js version note ===

Upstream requires Node.js >= 25.6.0. This port uses nodejs24, which is
the closest version currently available in MacPorts. The server should
work correctly; the EBADENGINE warning from npm during install is expected
and harmless. Update this port's dependency to nodejs25 once that port
becomes available in MacPorts.
"

livecheck.type      regex
